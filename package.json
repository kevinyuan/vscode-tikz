{
  "name": "vscode-tikzjax",
  "displayName": "TikZ in Markdown",
  "description": "Render TikZ diagrams in Markdown/Marp live preview and export editable PPTX",
  "version": "0.4.31",
  "publisher": "kevinyuan",
  "icon": "icon.png",
  "author": {
    "name": "Kevin Yuan"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kevinyuan/vscode-tikz"
  },
  "bugs": {
    "url": "https://github.com/kevinyuan/vscode-tikz/issues"
  },
  "homepage": "https://github.com/kevinyuan/vscode-tikz#readme",
  "keywords": [
    "tikz",
    "latex",
    "markdown",
    "diagram",
    "visualization",
    "math",
    "tikzjax",
    "svg",
    "preview",
    "render",
    "marp",
    "pptx",
    "powerpoint",
    "presentation",
    "pgfplots",
    "circuitikz",
    "scientific",
    "engineering"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Programming Languages",
    "Education",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "markdown.markdownItPlugins": true,
    "markdown.previewStyles": [
      "./media/tikz-preview.css"
    ],
    "markdown.previewScripts": [
      "./media/marp-thumbnails.js"
    ],
    "grammars": [
      {
        "scopeName": "markdown.tikz.codeblock",
        "path": "./syntaxes/tikz-injection.json",
        "injectTo": [
          "text.html.markdown"
        ],
        "embeddedLanguages": {
          "meta.embedded.block.tikz": "latex"
        }
      }
    ],
    "commands": [
      {
        "command": "tikz.openPreview",
        "title": "Open TikZ Preview",
        "category": "TikZ",
        "when": "editorLangId == markdown"
      },
      {
        "command": "tikz.refreshDiagrams",
        "title": "Refresh TikZ Diagrams",
        "category": "TikZ",
        "when": "editorLangId == markdown"
      },
      {
        "command": "tikz.clearCache",
        "title": "Clear TikZ Cache",
        "category": "TikZ",
        "when": "editorLangId == markdown"
      },
      {
        "command": "tikz.resetEngine",
        "title": "Reset TikZJax Engine",
        "category": "TikZ",
        "when": "editorLangId == markdown"
      },
      {
        "command": "tikz.exportMarpPptx",
        "title": "Export Marp Slides to PPTX",
        "category": "TikZ",
        "icon": "$(desktop-download)"
      },
      {
        "command": "tikz.toggleThumbnails",
        "title": "Toggle Slide Thumbnails",
        "category": "TikZ",
        "when": "editorLangId == markdown"
      },
      {
        "command": "tikz.toggleMarpPptxNotes",
        "title": "Toggle Speaker Notes Export",
        "category": "TikZ"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "tikz.exportMarpPptx",
          "group": "navigation",
          "when": "editorLangId == markdown && tikz.isMarpFile"
        },
        {
          "command": "tikz.exportMarpPptx",
          "group": "navigation",
          "when": "activeWebviewPanelId == 'markdown.preview' && tikz.isMarpFile"
        },
        {
          "command": "tikz.exportMarpPptx",
          "group": "navigation",
          "when": "activeCustomEditorId == 'vscode.markdown.preview.editor' && tikz.isMarpFile"
        }
      ]
    },
    "views": {
      "explorer": [
        {
          "id": "tikzMarpSlides",
          "name": "Marp Slides",
          "when": "tikz.isMarpFile"
        }
      ]
    },
    "configuration": {
      "title": "TikZ in Markdown",
      "properties": {
        "tikzjax.invertColorsInDarkMode": {
          "type": "boolean",
          "default": true,
          "description": "Automatically invert diagram colors when using a dark theme"
        },
        "tikzjax.renderTimeout": {
          "type": "number",
          "default": 15000,
          "minimum": 1000,
          "maximum": 60000,
          "description": "Maximum time (in milliseconds) to wait for a diagram to render before timing out"
        },
        "tikzjax.autoPreview": {
          "type": "boolean",
          "default": false,
          "description": "Automatically open preview panel when opening a Markdown file with TikZ diagrams"
        },
        "tikzjax.previewPosition": {
          "type": "string",
          "enum": [
            "side",
            "below",
            "window"
          ],
          "default": "side",
          "enumDescriptions": [
            "Open preview beside the editor",
            "Open preview below the editor",
            "Open preview in a separate window"
          ],
          "description": "Default position for the preview panel"
        },
        "tikzjax.marpPptxEditable": {
          "type": "boolean",
          "default": true,
          "description": "Use --pptx-editable when exporting Marp slides to PPTX (requires LibreOffice). Produces editable slides but may cause math formula misalignment. Disable for pixel-accurate math rendering."
        },
        "tikzjax.marpPptxNotes": {
          "type": "boolean",
          "default": true,
          "description": "Include speaker notes (<!-- ... --> HTML comments) when exporting Marp slides to PPTX."
        },
        "tikzjax.exportFormat": {
          "type": "string",
          "enum": [
            "pptx",
            "pdf"
          ],
          "default": "pptx",
          "description": "Last used export format (pptx or pdf). Updated automatically when you export."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "esbuild": "^0.28.0",
    "eslint": "^8.54.0",
    "fast-check": "^4.5.3",
    "jest": "^30.2.0",
    "sharp": "^0.34.5",
    "ts-jest": "^29.4.6",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@xmldom/xmldom": "^0.8.11",
    "jszip": "^3.10.1",
    "localforage": "^1.10.0",
    "node-tikzjax": "^1.0.5",
    "svgo": "^3.0.5",
    "temml": "^0.13.1",
    "tslib": "^2.8.1"
  }
}
